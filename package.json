{
  "name": "jsona",
  "version": "1.12.1",
  "description": "Provide data formatters (data model builder & json builder) to work with JSON API specification v1.0 in your JavaScript / TypeScript code",
  "keywords": [
    "json-api",
    "jsonapi",
    "json:api",
    "json-api-redux",
    "json api redux",
    "json-api angular",
    "json api typescript",
    "data formatter",
    "data converter",
    "data serializer",
    "formatter",
    "converter",
    "serializer",
    "json api json",
    "json",
    "redux-object",
    "rest",
    "rest api",
    "graphql",
    "graphql alternative",
    "json-api-normalizer"
  ],
  "homepage": "https://github.com/olosegres/jsona#readme",
  "bugs": {
    "url": "https://github.com/olosegres/jsona/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/olosegres/jsona"
  },
  "license": "MIT",
  "author": "Sergei Solo <olosegres@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.cjs",
      "default": "./lib/index.js"
    }
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "prebuild": "npm run clean",
    "build": "rollup --config rollup.config.js",
    "clean": "rm -rf ./lib/*",
    "test": "env NODE_ENV=test node --import tsx --test tests/**/*.test.*",
    "preversion": "npm run build && npm test"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "12.1.2",
    "@types/chai": "^5.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.8",
    "chai": "^5.2.0",
    "rollup": "^4.34.9",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
