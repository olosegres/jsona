{
    "compilerOptions": {
        "target": "ES2015",
        "module": "ES2015",
        "declaration": true,
        "sourceMap": true,
        "outDir": "lib",
        "strict": false,
        "removeComments": true,
        "allowSyntheticDefaultImports": true,
        "moduleResolution": "bundler",
        "skipLibCheck": true
    },
    "include": [
        "src/**/*",
        "tests/**/*"
    ],
    "exclude": [
        "node_modules",
        "lib"
    ]
}
